{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polar-sh/better-auth": "^1.8.3",
    "@polar-sh/sdk": "^0.47.1",
    "@workspace/contracts": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.11.4",
    "postgres": "^3.4.5",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.9.3"
  }
}
