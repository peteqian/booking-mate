{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --target bun --production --outdir dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "preview": "NODE_ENV=production bun --env-file=../../.env dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.957.0",
    "@aws-sdk/s3-request-presigner": "^3.957.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@workspace/contracts": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.11.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "resend": "^6.12.2",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.9.3"
  }
}
