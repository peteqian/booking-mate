{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/contracts": "workspace:*",
    "hono": "^4.11.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
