# Brand identity (used in UI, emails, service names, container names)
BUSINESS_NAME=
BUSINESS_SLUG=
VITE_BUSINESS_NAME=
VITE_BUSINESS_SLUG=

# Database Configuration
POSTGRES_USER=buching
POSTGRES_PASSWORD=buching_password
POSTGRES_DB=buching
DATABASE_URL=postgresql://buching:buching_password@localhost:5433/buching

# Application Ports
SERVER_PORT=3456
WEB_PORT=5678
WEB_URL=http://localhost:5678
VITE_SERVER_URL=http://localhost:3456
VITE_PUBLIC_SITE_URL=http://lvh.me:5678
PUBLIC_HOST_ALLOWLIST=.lvh.me,.localhost,localhost
PLATFORM_HOST_SUFFIXES=.lvh.me,.localhost,localhost

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3456

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Observability
LOG_LEVEL=
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Payments
# Generate via: bun -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAYMENT_ENCRYPTION_KEY=

# Stripe Connect (set all 3 or none)
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
# Platform fee percent applied to event ticket payments via Stripe Connect (0 to disable)
STRIPE_PLATFORM_FEE_PERCENT=1

# Cloudflare R2 public assets
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
