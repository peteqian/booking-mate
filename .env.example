# Database Configuration
POSTGRES_USER=booking_mate
POSTGRES_PASSWORD=booking_mate_password
POSTGRES_DB=booking_mate
DATABASE_URL=postgresql://booking_mate:booking_mate_password@localhost:5433/booking_mate

# Application Ports
SERVER_PORT=3456
WEB_PORT=5678
WEB_URL=http://localhost:5678
VITE_SERVER_URL=http://localhost:3456
VITE_PUBLIC_SITE_URL=http://localhost:5678
VITE_PUBLIC_HOST_SUFFIXES=.traefik.me,.lvh.me

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3456

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Polar.sh
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ENVIRONMENT=sandbox

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Observability
LOG_LEVEL=
OTEL_SERVICE_NAME=booking-mate-server
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Payments
# Generate via: bun -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAYMENT_ENCRYPTION_KEY=

# Stripe Connect (set all 3 or none)
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
